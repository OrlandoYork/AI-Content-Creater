# Docker部署环境变量
# 复制此文件为 .env 后按需修改

# 端口映射 (避免和本地服务冲突)
PG_PORT=5433
REDIS_PORT=6380
BACKEND_PORT=8083
FRONTEND_PORT=5173

# AI API配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT=180
DEEPSEEK_ENABLED=true

# 调试模式 (生产环境请设为false)
DEBUG=false
